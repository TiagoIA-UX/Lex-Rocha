# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic — relatório final (API Route, nunca no browser)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq — triagem/classificação APENAS com texto sem dados pessoais do cliente
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=contato@lexrocha.com.br

# Stripe — modo teste (Developers → API keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Nuvem Fiscal NFS-e (fase futura)
NUVEM_FISCAL_CLIENT_ID=
NUVEM_FISCAL_CLIENT_SECRET=

# URL pública da aplicação (dev: porta 3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp — DDI + DDD + número (ex.: 5512996887993)
NEXT_PUBLIC_WHATSAPP_NUMBER=5512996887993

# Senha do workspace interno (/pesquisa-documental) — obrigatório em produção
WORKSPACE_SECRET=

# Chave interna para logs de acesso (opcional; usa WORKSPACE_SECRET se vazio)
INTERNAL_LOG_SECRET=
