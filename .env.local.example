# =============================================================================
# Lex Rocha — exemplo de configuração (Next.js)
# Copie para `.env.local` e preencha. NUNCA versionar o `.env.local` real.
# Legenda: [obrigatório] / [opcional] / (default: ...) quando há valor padrão.
# =============================================================================

# --- App -----------------------------------------------------------------
# Base URL pública. Usada em links de e-mail e no redirect do OAuth.
NEXT_PUBLIC_APP_URL=http://localhost:3000          # [obrigatório em prod] (default: http://localhost:3000)

# --- Supabase ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=                          # [obrigatório]
NEXT_PUBLIC_SUPABASE_ANON_KEY=                     # [obrigatório]
SUPABASE_SERVICE_ROLE_KEY=                         # [obrigatório] segredo server-side (nunca expor ao browser)

# --- IA: triagem e relatórios -------------------------------------------
GROQ_API_KEY=                                      # [obrigatório] triagem (Groq)
ANTHROPIC_API_KEY=                                 # [obrigatório] geração de relatórios (Claude)

# --- Pagamentos: Stripe --------------------------------------------------
STRIPE_SECRET_KEY=                                 # [obrigatório] sk_test_... (homolog) / sk_live_... (prod)
STRIPE_WEBHOOK_SECRET=                             # [obrigatório] whsec_... (endpoint /api/stripe/webhook)

# --- E-mail: Resend ------------------------------------------------------
RESEND_API_KEY=                                    # [opcional] sem isto, e-mails não são enviados
RESEND_FROM_EMAIL=                                 # [opcional] (default: e-mail do SITE)

# --- Admin (painel /admin: NFS-e, financeiro, export IR) -----------------
ADMIN_SECRET=                                      # [obrigatório] mínimo 16 caracteres (assina o cookie de sessão)
ADMIN_EMAIL=                                       # [obrigatório] allowlist; vírgula separa vários
GOOGLE_OAUTH_CLIENT_ID=                            # [obrigatório] ...apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=                        # [obrigatório] GOCSPX-...
# Redirect URI a autorizar no Google Console:
#   {NEXT_PUBLIC_APP_URL}/api/admin/auth/google/callback

# --- NFS-e: Nuvem Fiscal -------------------------------------------------
NUVEM_FISCAL_CLIENT_ID=                            # [obrigatório p/ emitir]
NUVEM_FISCAL_CLIENT_SECRET=                        # [obrigatório p/ emitir]
NUVEM_FISCAL_AMBIENTE=homologacao                  # homologacao | producao (default: homologacao)
NFSE_PRESTADOR_CNPJ=61699939000180                 # somente dígitos (default: 61699939000180)
NFSE_CMUN_PRESTADOR=3510500                        # código IBGE do município (default: 3510500)
NFSE_CTRIB_NAC=1701                                # cód. tributação nacional / item LC 116 (default: 1701)
NFSE_ALIQUOTA_ISS=2                                # alíquota ISS em % (default: 2)
NFSE_DESCRICAO_SERVICO=Pesquisa documental de precedentes em fontes públicas (relatório informativo).

# --- WhatsApp (notificações / contato) ----------------------------------
WHATSAPP_ACCESS_TOKEN=                             # [opcional] Cloud API token
WHATSAPP_PHONE_NUMBER_ID=                          # [opcional] id do número emissor
WHATSAPP_TO_NUMBER=                                # [opcional] destino interno das notificações
NEXT_PUBLIC_WHATSAPP_NUMBER=                       # [opcional] número exibido no site (CTA)

# --- Contato / interno ---------------------------------------------------
CONTACT_EMAIL=                                     # [opcional] destino do formulário de contato
WORKSPACE_SECRET=                                  # [opcional] protege rotas internas (/api/workspace, logs)
INTERNAL_LOG_SECRET=                               # [opcional] segredo de logs internos (fallback p/ WORKSPACE_SECRET)
